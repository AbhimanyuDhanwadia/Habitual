# Habitual Server Environment Variables

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/habitual

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=habitual_dev_secret_key_change_in_production

# JWT Expiry
JWT_EXPIRES_IN=7d

# Server Port
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Google OAuth Client ID (optional — for Google SSO)
# GOOGLE_CLIENT_ID=your_google_client_id_here
