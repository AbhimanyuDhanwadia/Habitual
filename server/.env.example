# Habitual Server Environment Variables

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/habitual

# Server Port
PORT=5001

# Client URL(s) for CORS. Use a comma-separated list for preview + production.
CLIENT_URL=http://localhost:5173

# Firebase Admin service account JSON for deployed environments.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
